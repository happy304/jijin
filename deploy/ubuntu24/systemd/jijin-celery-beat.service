[Unit]
Description=Jijin Celery Beat
After=network.target redis-server.service postgresql.service

[Service]
Type=simple
WorkingDirectory=/opt/jijin/backend
EnvironmentFile=/opt/jijin/backend/.env
ExecStart=/opt/jijin/backend/.venv/bin/python -m celery -A app.tasks.celery_app beat --loglevel=info
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target

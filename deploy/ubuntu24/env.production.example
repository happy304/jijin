APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_CORS_ORIGINS=http://你的服务器公网IP

DATABASE_URL=postgresql+asyncpg://fundquant:fundquant@localhost:5432/fundquant
DATABASE_SYNC_URL=postgresql+psycopg://fundquant:fundquant@localhost:5432/fundquant

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TIMEZONE=Asia/Shanghai

PERSONAL_MODE=true
FEATURE_AI=false
FEATURE_ADVISOR_GOVERNANCE=false
FEATURE_FULL_MONITORING=false
SCHEDULE_MODE=light

PROMETHEUS_ENABLED=false
DB_AUTO_MIGRATE=true

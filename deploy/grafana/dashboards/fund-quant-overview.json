    {
      "type": "stat",
      "id": 1,
      "title": "Ingest Success Rate (7d)",
      "datasource": { "type": "prometheus", "uid": "fqp-prometheus" },
      "description": "Percentage of successful ingest requests over the last 7 days.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "fqp-prometheus" },
          "editorMode": "code",
          "expr": "sum(increase(ingest_requests_total{status=\"success\"}[7d])) / sum(increase(ingest_requests_total[7d]))",
          "legendFormat": "Success Rate",
          "refId": "A"

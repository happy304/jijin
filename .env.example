# =============================================================
# Fund Quant Platform - Environment Variables (Example)
# 复制为 `.env` 后按需修改，.env 不会被提交到版本库
# =============================================================

# ----- Runtime -----
APP_ENV=development            # development | staging | production
APP_NAME=fund-quant-platform
DEBUG=true
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
TIMEZONE=Asia/Shanghai
SECRET_KEY=change-me-in-prod

# ----- API -----
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_PREFIX=/api/v1

# ----- Database (PostgreSQL + TimescaleDB) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fundquant
POSTGRES_PASSWORD=fundquant
POSTGRES_DB=fundquant
# 使用 asyncpg 驱动
DATABASE_URL=postgresql+asyncpg://fundquant:fundquant@localhost:5432/fundquant
# 同步 URL（Alembic 使用）
DATABASE_SYNC_URL=postgresql+psycopg://fundquant:fundquant@localhost:5432/fundquant
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
# 启动时自动执行 Alembic 迁移（推荐开发/测试开启，生产关闭后由发布流程手动执行）
DB_AUTO_MIGRATE=true

# ----- Redis (缓存 + Celery broker/backend) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ----- Celery -----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_TIMEZONE=Asia/Shanghai

# ----- Personal-use feature profile -----
# 个人默认模式：收敛高级入口，保留研究/筛选/组合检查/回测验证主流程
PERSONAL_MODE=true
FEATURE_AI=false
FEATURE_ADVISOR_GOVERNANCE=false
FEATURE_FULL_MONITORING=false
# light: 个人日常数据更新；research: 增加研究任务；full: 启用完整调度
SCHEDULE_MODE=light

# ----- Data sources -----
# 东方财富天天基金（主源）
EASTMONEY_BASE_URL=https://fundgz.1234567.com.cn
EASTMONEY_USER_AGENT_POOL=
EASTMONEY_REQUEST_TIMEOUT=10
EASTMONEY_RATE_LIMIT_PER_SEC=5

# AkShare 备源
AKSHARE_ENABLED=true

# 代理池（可选）
HTTP_PROXY=
HTTPS_PROXY=
PROXY_POOL_URL=

# 快照存储根目录
SNAPSHOT_DIR=./local_data/snapshots
BACKUP_DIR=./local_data/backups

# ----- AI / LLM 配置 -----
AI_ENABLED=true
# 默认提供商：openai_compat | anthropic | deepseek | tongyi | zhipu | moonshot
AI_DEFAULT_PROVIDER=openai_compat
AI_FALLBACK_PROVIDER=

# OpenAI 兼容（含 DeepSeek、智谱、月之暗面、MiMo 等）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# 预算与缓存
LLM_CACHE_TTL_SECONDS=604800   # 7 天
LLM_DAILY_TOKEN_LIMIT=2000000
LLM_MONTHLY_USD_LIMIT=50

# ----- 观测性 -----
PROMETHEUS_ENABLED=true
PROMETHEUS_PATH=/metrics
# Prometheus 容器（docker-compose）本地保留窗口与映射端口
PROMETHEUS_RETENTION=15d
PROMETHEUS_PORT_HOST=9090
# Grafana（docker-compose）默认管理员账号与映射端口
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT_HOST=3000

# ----- 通知渠道 -----
NOTIFY_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

NOTIFY_WECOM_ENABLED=false
WECOM_WEBHOOK_URL=

NOTIFY_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
